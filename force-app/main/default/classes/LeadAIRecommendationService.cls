public with sharing class LeadAIRecommendationService{
    private static final String PROMPT_TEMPLATE_DEV_NAME = 'Lead_Execution_Recommendation';

    public class RecommendationDTO{
        @AuraEnabled
        public String priorityBucket;
        @AuraEnabled
        public String nextAction;
        @AuraEnabled
        public List<String> talkingPoints;
        @AuraEnabled
        public List<String> reasonSummary;

        @AuraEnabled
        public String rawJSON;
    }

    @AuraEnabled
    public static RecommendationDTO getRecommendation(Id leadId) {
        if(leadId == null) {
            throw new AuraHandledException('Lead Id is required to get AI recommendation.');
        }

        //Build input params for the prompt template
        Map<String, ConnectApi.WrappedValue> inputParams = new Map<String, ConnectApi.WrappedValue>();
        ConnectApi.WrappedValue leadWrapped = new ConnectApi.WrappedValue();
        leadWrapped.value = new Map<String, Object>{ 'id' => (String)leadId };
        inputParams.put('Input:Lead', leadWrapped);

        //Execute the prompt
        ConnectApi.EinsteinPromptTemplateGenerationsInput genInput = new ConnectApi.EinsteinPromptTemplateGenerationsInput();
        genInput.inputParams = inputParams;
        genInput.isPreview = false;
        genInput.additionalConfig = new ConnectApi.EinsteinLlmAdditionalConfigInput();
        genInput.additionalConfig.applicationName = 'PromptBuilderPreview';

        String raw = executePrompt(PROMPT_TEMPLATE_DEV_NAME, genInput);

        //Parse/validate JSON
        RecommendationDTO dto = parseRecommendation(raw);
        dto.rawJson = raw;
        return dto;

    }

    private static String executePrompt(String promptDevName, ConnectApi.EinsteinPromptTemplateGenerationsInput genInput) {
        try {
            ConnectApi.EinsteinPromptTemplateGenerationsRepresentation genOutput = ConnectApi.EinsteinLLM.generateMessagesForPromptTemplate(promptDevName, genInput);
            if(genOutput != null && genOutput.generations != null && !genOutput.generations.isEmpty()) {
                return genOutput.generations[0].text;
            } else {
                throw new AuraHandledException('No recommendation generated by the AI.');
            }
        } catch(Exception ex) {
            throw new AuraHandledException('AI generation failed: ' + ex.getMessage());
        }
    }

    private static RecommendationDTO parseRecommendation(String raw) {
    try {
        Map<String, Object> resultMap =
            (Map<String, Object>) JSON.deserializeUntyped(raw);

        RecommendationDTO dto = new RecommendationDTO();
        dto.priorityBucket = (String) resultMap.get('priority_bucket');
        dto.nextAction     = (String) resultMap.get('next_action');

        dto.talkingPoints  = convertToStringList(resultMap.get('talking_points'));
        dto.reasonSummary  = convertToStringList(resultMap.get('reason_summary'));

        return dto;

    	} catch(Exception ex) {
        throw new AuraHandledException(
            'Failed to parse AI recommendation: ' + ex.getMessage()
        );
    	}
	}

    private static List<String> convertToStringList(Object value) {
        List<String> output = new List<String>();
    
        if (value == null) return output;
    
        if (value instanceof List<Object>) {
            for (Object item : (List<Object>) value) {
                if (item != null) {
                    output.add(String.valueOf(item));
                }
            }
        } else {
            output.add(String.valueOf(value));
        }
    
        return output;
    }

    @AuraEnabled
    public static void applyRecommendation(Id leadId, RecommendationDTO dto) {
        if (leadId == null) {
            throw new AuraHandledException('Lead Id is required.');
        }
        if (dto == null) {
            throw new AuraHandledException('Recommendation data is required.');
        }

        Lead l = new Lead(
            Id = leadId,
            AI_Priority_Bucket__c = dto.priorityBucket,
            AI_Next_Action__c     = dto.nextAction,
            AI_Talking_Points__c  = formatBullets(dto.talkingPoints),
            AI_Reason_Summary__c  = formatBullets(dto.reasonSummary),
            AI_Last_Generated__c  = System.now() // optional field if you have it
        );

        update l;
    }

    public static String formatBullets(List<String> items) {
        if (items == null || items.isEmpty()) return null;
        // Store as bullets in a long text field for readability
        List<String> cleaned = new List<String>();
        for (String s : items) {
            if (String.isNotBlank(s)) cleaned.add(s.trim());
        }
        if (cleaned.isEmpty()) return null;

        return '• ' + String.join(cleaned, '\n• ');
    }

}